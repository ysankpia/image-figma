# Current local defaults for the Go Draft runtime. Copy values into an
# untracked .env.local when real credentials are needed.
API_BASE_URL=http://localhost:8000/api
PUBLIC_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=*
IMAGE_FIGMA_LOAD_LOCAL_ENV=true

# Retained Python /api/upload-preview storage knobs. This path is historical
# unless a task explicitly targets it.
STORAGE_ROOT=backend/storage
DATABASE_PATH=backend/storage/app.db
MAX_UPLOAD_BYTES=10485760
UPLOAD_PREVIEW_PROFILE=production

# OCR. Keep fake/empty for local smoke; use baidu_ppocrv5 for real OCR.
OCR_PROVIDER=fake
OCR_MIN_CONFIDENCE=0.70
BAIDU_PADDLE_OCR_TOKEN=
BAIDU_PADDLE_OCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
BAIDU_PADDLE_OCR_MODEL=PP-OCRv5
BAIDU_PADDLE_OCR_POLL_INTERVAL_SECONDS=5
BAIDU_PADDLE_OCR_TIMEOUT_SECONDS=120

# Go Draft server.
DRAFT_SERVER_ADDR=127.0.0.1:8000
DRAFT_SERVER_STORAGE_ROOT=./storage/draft_server
DRAFT_SERVER_MAX_UPLOAD_BYTES=10485760
DRAFT_SERVER_VISION_ENABLED=false

# Optional OpenAI-compatible vision detector used by Draft when
# DRAFT_SERVER_VISION_ENABLED=true, or by cmd/draftdetect / cmd/draftcompile -vision.
VISION_PROVIDER=openai-compatible
VISION_WIRE_API=responses
VISION_BASE_URL=https://api.openai.com
VISION_API_KEY=
VISION_MODEL=
VISION_DETECTOR_PASSES=layout,imageview,background,bottom_nav
VISION_DETECTOR_CONCURRENCY=3
VISION_MAX_IMAGE_SIDE=1280
VISION_TIMEOUT_SECONDS=90
VISION_TEMPERATURE=0
VISION_STREAM=false
VISION_REVIEW_ENABLED=false

# Optional layout advisor experiment. This is an offline A/B harness for
# grouping relationships; it must not replace OCR/M29 bbox/text authority.
LAYOUT_ADVISOR_WIRE_API=responses
LAYOUT_ADVISOR_BASE_URL=https://api.openai.com
LAYOUT_ADVISOR_API_KEY=
LAYOUT_ADVISOR_MODEL=
LAYOUT_ADVISOR_TIMEOUT_SECONDS=120
LAYOUT_ADVISOR_TEMPERATURE=0

# Optional Unified Vision layout experiment. This is disabled by default and
# writes parallel experiment artifacts without replacing baseline layoutcompile output.
UNIFIED_VISION_ENABLED=false
UNIFIED_VISION_PROVIDER=openai-compatible
UNIFIED_VISION_WIRE_API=responses
UNIFIED_VISION_BASE_URL=https://api.openai.com
UNIFIED_VISION_API_KEY=
UNIFIED_VISION_MODEL=
UNIFIED_VISION_CONCURRENCY=3
UNIFIED_VISION_TIMEOUT_SECONDS=180
UNIFIED_VISION_TEMPERATURE=0
UNIFIED_VISION_TRANSPORT_RETRIES=3
UNIFIED_VISION_REPAIR_ATTEMPTS=1
UNIFIED_VISION_MAX_ITEMS_PER_BATCH=30
UNIFIED_VISION_HARD_MAX_ITEMS_PER_BATCH=45
UNIFIED_VISION_MAX_COMPLEXITY=110
UNIFIED_VISION_MIN_CONFIDENCE=0.70
UNIFIED_VISION_MAX_FIT_RATIO=1.01
UNIFIED_VISION_MAX_Y_SPREAD_FACTOR=1.60
UNIFIED_VISION_MAX_GAP=96
UNIFIED_VISION_MAX_GAP_VARIANCE=4096
UNIFIED_VISION_CROP_PADDING=10
