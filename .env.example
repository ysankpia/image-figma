SLICE_STUDIO_AI_SLICE_JPEG_QUALITY=75
SLICE_STUDIO_AI_SLICE_MAX_BOXES_PER_PAGE=80
SLICE_STUDIO_AI_SLICE_OVERVIEW_REVIEW=true
