SLICE_STUDIO_AI_SLICE_TIMEOUT_SECONDS=120
SLICE_STUDIO_AI_SLICE_TRANSPORT_RETRIES=2
SLICE_STUDIO_AI_SLICE_BATCH_CONCURRENCY=4
SLICE_STUDIO_AI_SLICE_TILE_COUNT=6
SLICE_STUDIO_AI_SLICE_TILE_OVERLAP=64
