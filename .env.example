# Current product/backend defaults.
API_BASE_URL=http://localhost:8000/api
PUBLIC_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=*
STORAGE_ROOT=backend/storage
DATABASE_PATH=backend/storage/app.db
MAX_UPLOAD_BYTES=10485760
IMAGE_FIGMA_LOAD_LOCAL_ENV=true

# OCR. Keep fake for local smoke; use baidu_ppocrv5 for real OCR.
OCR_PROVIDER=fake
OCR_MIN_CONFIDENCE=0.70
BAIDU_PADDLE_OCR_TOKEN=
BAIDU_PADDLE_OCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
BAIDU_PADDLE_OCR_MODEL=PP-OCRv5
BAIDU_PADDLE_OCR_POLL_INTERVAL_SECONDS=5
BAIDU_PADDLE_OCR_TIMEOUT_SECONDS=120

# Upload preview artifact profile.
UPLOAD_PREVIEW_PROFILE=production

# Go Codia Beta server used by the plugin "Generate Beta" path.
CODIA_SERVER_ADDR=127.0.0.1:8000
CODIA_SERVER_STORAGE_ROOT=./storage/codia_server
CODIA_SERVER_MAX_UPLOAD_BYTES=10485760
CODIA_SERVER_DETECTOR_CANDIDATES=

# Go Codia-like offline/Beta UI detector. This is not part of /api/upload-preview
# unless run explicitly through cmd/codiadetector or codiacompile -detector-candidates.
CODIA_UI_DETECTOR_PROVIDER=openai-responses
CODIA_UI_DETECTOR_WIRE_API=responses
CODIA_UI_DETECTOR_BASE_URL=https://api.openai.com
CODIA_UI_DETECTOR_API_KEY=
CODIA_UI_DETECTOR_MODEL=gpt-5.5
CODIA_UI_DETECTOR_PASSES=layout,imageview,background,bottom_nav
CODIA_UI_DETECTOR_MAX_IMAGE_SIDE=1280
CODIA_UI_DETECTOR_TIMEOUT_SECONDS=180
CODIA_UI_DETECTOR_TEMPERATURE=0

# Optional fallback used only by codiadetector when CODIA_UI_DETECTOR_API_KEY is empty.
OPENAI_API_KEY=
