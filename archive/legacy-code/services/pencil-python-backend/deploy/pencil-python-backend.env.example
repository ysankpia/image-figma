# Copy to /etc/pencil-python-backend/pencil-python-backend.env on a server.
# Keep secrets such as BAIDU_PADDLE_OCR_TOKEN out of git.

PENCIL_BACKEND_ADDR=127.0.0.1:8100
PENCIL_BACKEND_STORAGE_ROOT=/data/pencil-python-backend
PENCIL_BACKEND_M29EXTRACT=/opt/pencil-python-backend/services/backend-go/bin/m29extract
PENCIL_BACKEND_PSDLIKE_ROOT=/opt/pencil-python-backend/services/psdlike-python
PENCIL_BACKEND_PSDLIKE_TILE_SIZE=8
PENCIL_BACKEND_DEFAULT_BOUNDARY_SOURCE=psdlike
PENCIL_BACKEND_MAX_UPLOAD_BYTES=10485760
PENCIL_BACKEND_MAX_FILES=20
PENCIL_BACKEND_MAX_WORKERS=1
PENCIL_BACKEND_CORS_ALLOW_ORIGINS=*

OCR_PROVIDER=baidu_ppocrv5
BAIDU_PADDLE_OCR_TOKEN=
BAIDU_PADDLE_OCR_MODEL=PP-OCRv5
