{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@image-figma/dsl-schema": ["packages/dsl-schema/src/index.ts"],
      "@image-figma/image-to-figma-renderer": ["packages/image-to-figma-renderer/src/index.ts"]
    }
  }
}
