{
  "name": "slice-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
    "dev:web": "next dev --hostname 127.0.0.1 --port 3010",
    "dev:api": "bun --watch server/index.ts",
    "server": "bun server/index.ts",
    "build": "next build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "bun run typecheck && bun run test",
    "smoke": "bun scripts/smoke.ts",
    "start:prod": "bun server/start-production.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "elysia": "^1.4.17",
    "konva": "^10.0.12",
    "lucide-react": "^1.17.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-konva": "^19.0.12",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
